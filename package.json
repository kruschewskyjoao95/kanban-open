{
  "name": "kanban",
  "version": "0.1.0",
  "description": "Local-first Kanban board (Trello-like) — Tauri 2 + Svelte + Rust",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:build:linux": "NO_STRIP=1 APPIMAGE_EXTRACT_AND_RUN=1 tauri build",
    "tauri:build:appimage": "NO_STRIP=1 APPIMAGE_EXTRACT_AND_RUN=1 tauri build --bundles appimage",
    "tauri:build:deb": "tauri build --bundles deb"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
